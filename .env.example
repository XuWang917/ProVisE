# Required by the tested OpenAI-compatible pipeline.
OPENAI_API_KEY=your_openai_api_key_here

# Uncomment only when using a compatible endpoint instead of OpenAI directly.
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint.example/v1

# Optional model overrides. These are the defaults used by the published protocols.
# PROVISE_AGENT_MODEL=gpt-5.4
# PROVISE_PARSER_MODEL=gpt-5.4
# PROVISE_PROTOCOL_MODEL=gpt-image-2
# PROVISE_EVALUATION_MODEL=gpt-image-2

# Optional resources for suite discovery and deterministic CLIP readout.
# PROVISE_BENCHMARK_ROOT=/path/to/benchmarks
# PROVISE_CLIP_MODEL=/path/to/clip-ViT-B-32
